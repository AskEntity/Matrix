#!/bin/sh
# Pre-commit hook: enforces typecheck, lint, and tests before every commit.
# Install: git config core.hooksPath .hooks

set -e

# Strip git env vars so test subprocesses (git init, worktree ops) work correctly
unset GIT_DIR GIT_WORK_TREE GIT_INDEX_FILE GIT_OBJECT_DIRECTORY GIT_ALTERNATE_OBJECT_DIRECTORIES

echo "Running typecheck..."
bun run typecheck

echo "Running lint..."
bun run check

echo "Running tests..."
bun test --bail src/daemon.test.ts src/project-manager.test.ts src/task-tracker.test.ts src/worktree-manager.test.ts src/direct-provider.test.ts

echo "All checks passed."
